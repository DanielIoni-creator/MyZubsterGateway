# Admin Panel
REACT_APP_ADMIN_API_URL=http://localhost:8080/api/v1/admin

# CORS
CORS_ORIGIN=*

# Rate Limiting
RATE_LIMIT_WINDOW=900000
RATE_LIMIT_MAX=100