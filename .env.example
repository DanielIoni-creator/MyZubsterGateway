# Configurazione Monero Mainnet
MONERO_NETWORK=mainnet
MONERO_DAEMON_ADDRESS=node.moneroworld.com:18081
MONERO_RPC_PORT=18081

# Configurazione MongoDB
MONGODB_URI=mongodb://localhost:27017/myzubster

# Configurazione Server
PORT=3002

# Configurazione Sicurezza
JWT_SECRET=your-secret-key-here

# Configurazione AI (DeepSeek)
DEEPSEEK_URL=http://localhost:11434/api/generate

# Configurazione Security Bot
SECURITY_TARGET=https://your-domain.com

# Configurazione Webhook
WEBHOOK_RETRY_DELAYS=5,30,120,600
WEBHOOK_MAX_RETRIES=4
