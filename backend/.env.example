PORT=3000
MONGODB_URI=mongodb://localhost:27017/myzubster
JWT_SECRET=change_me

# Monero payment gateway
# Prefer a self-hosted MoneroPay instance when available. The backend never exposes wallet secrets to Android clients.
MONEROPAY_URL=http://127.0.0.1:5000

# Wallet RPC fallback used when MONEROPAY_URL is unset. This should normally be a view-only/merchant wallet service.
MONERO_WALLET_RPC_URL=http://127.0.0.1:18083/json_rpc

# Daemon/node URL used for health checks and block height context. Can be your own monerod or a public node.
MONERO_NODE_URL=http://127.0.0.1:18081/json_rpc
MONERO_RPC_USERNAME=
MONERO_RPC_PASSWORD=

# Merchant behaviour
MONERO_ACCOUNT_INDEX=0
MONERO_CONFIRMATIONS_DEFAULT=0
MONERO_PAYMENT_STORE=./data/payments.json
PAYMENT_WEBHOOK_SECRET=
